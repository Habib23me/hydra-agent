# =============================================================================
# Slack Configuration (Required)
# =============================================================================
# Bot token (xoxb-) — from OAuth & Permissions page in your Slack app settings
# Required scopes: app_mentions:read, channels:history, channels:read, chat:write
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-level token (xapp-) — from App Level Tokens in your Slack app settings
# Must have connections:write scope. Socket Mode must be enabled.
SLACK_APP_TOKEN=xapp-your-app-token

# =============================================================================
# GitHub MCP (Optional)
# =============================================================================
# Personal Access Token from https://github.com/settings/tokens
# Recommended scopes: repo, read:org
# Enables: reading repos, creating PRs, managing issues, code search
GITHUB_PERSONAL_ACCESS_TOKEN=

# =============================================================================
# Linear MCP (Optional — one key per workspace)
# =============================================================================
# API Keys from each Linear workspace: Settings → API → Personal API keys
# Enables: reading/creating issues, updating status, tracking work
# Add one env var per workspace, then map it in projects.json → linear_workspaces → api_key_env
# Example: LINEAR_API_KEY=lin_api_xxx, LINEAR_API_KEY_SECOND=lin_api_yyy
LINEAR_API_KEY=

# =============================================================================
# Working Directory (Optional)
# =============================================================================
# Default directory the agent works in. Set this to your project repo.
# The agent's file operations are restricted to this directory.
# Default: current directory where app.py is run
DEFAULT_CWD=/path/to/your/project

# =============================================================================
# Cost Guard (Optional)
# =============================================================================
# Maximum USD spend per Slack thread session before auto-stopping.
# The bot will stop responding and ask the user to start a new thread.
# Default: 10.00
MAX_SESSION_COST_USD=10.00

# Maximum USD a single turn (one user message → agent response) can spend.
# Prevents runaway tool loops from blowing through the session budget.
# Default: 3.00
MAX_TURN_COST_USD=3.00

# Maximum user messages per session before forcing a new thread.
# Keeps context size and costs manageable. Default: 30
MAX_SESSION_TURNS=30

# =============================================================================
# Personality (Optional)
# =============================================================================
# Adds a personality overlay to the bot's Slack messages.
# The bot still does all the same work — this just changes the *tone*.
# Available: gilfoyle, dinesh (or leave empty for default)
# Add your own in prompts/personalities/<name>.md
PERSONALITY=
